# =============================================================================
# SPESION 2.0 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
# =============================================================================

# ─── API Server ──────────────────────────────────────────────────────────────
# Generate a key:  python -c "import secrets; print(secrets.token_urlsafe(32))"
SPESION_API_KEY=change-me-to-a-random-secret
SPESION_DEBUG=false
LOG_LEVEL=INFO

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60

# Trusted hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# ─── LLM ─────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_LIGHT=llama3.2:3b
OLLAMA_MODEL_HEAVY=qwen2.5:7b

# Cloud LLM (at least one recommended for complex tasks)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLOUD_PROVIDER=openai

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_USER_IDS=

# ─── Notion ──────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_KNOWLEDGE_DATABASE_ID=
NOTION_CRM_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=
NOTION_GOALS_DATABASE_ID=
NOTION_PILLS_DATABASE_ID=
NOTION_BOOKS_DATABASE_ID=
NOTION_TRAININGS_DATABASE_ID=
NOTION_TRANSACTIONS_DATABASE_ID=

# ─── Finance ─────────────────────────────────────────────────────────────────
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_DEFAULT_TYPE=spot

# ─── Health / Fitness ────────────────────────────────────────────────────────
GARMIN_EMAIL=
GARMIN_PASSWORD=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ─── Other APIs ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=

GOOGLE_CREDENTIALS_PATH=data/google_calendar_credentials.json
GOOGLE_CALENDAR_ID=primary

TAVILY_API_KEY=
SEARCH_PROVIDER=duckduckgo

# ─── Whisper (local transcription) ───────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es

# ─── Storage ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/sessions.db
