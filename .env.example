# =============================================================================
# SPESION 3.0 — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!
#
# Quick setup:
#   Windows:    powershell -File scripts\spesion_setup.ps1
#   macOS/Linux: bash scripts/spesion_setup.sh
#   Any OS:     python setup.py
# =============================================================================

# ─── API Server ──────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SPESION_API_KEY=change-me-to-a-random-secret
SPESION_HOST=0.0.0.0
SPESION_PORT=8100
DEBUG=false
LOG_LEVEL=INFO

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60

# Trusted hosts (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000

# ─── LLM Configuration ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_LIGHT=llama3.2:3b
OLLAMA_MODEL_HEAVY=qwen2.5:7b

# Cloud LLM (at least one recommended for complex tasks)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLOUD_PROVIDER=openai

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ALLOWED_USER_IDS=

# ─── Notion (Knowledge Base) ────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_JOURNAL_DATABASE_ID=
NOTION_CRM_DATABASE_ID=
NOTION_BOOKS_DATABASE_ID=
NOTION_TRAININGS_DATABASE_ID=
NOTION_FINANCE_DATABASE_ID=
NOTION_TRANSACTIONS_DATABASE_ID=

# ─── Finance ─────────────────────────────────────────────────────────────────
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_DEFAULT_TYPE=spot

# ─── Health / Fitness ────────────────────────────────────────────────────────
GARMIN_EMAIL=
GARMIN_PASSWORD=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ─── Phone Calls (Twilio) ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
# For Gmail: use App Password → https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_NAME=SPESION

# ─── Other APIs ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_DEFAULT_OWNER=

GOOGLE_CREDENTIALS_PATH=/app/data/google_calendar_credentials.json
GOOGLE_CALENDAR_ID=primary

TAVILY_API_KEY=
SEARCH_PROVIDER=duckduckgo

# ─── Whisper (local transcription) ──────────────────────────────────────────
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es

# ─── Autonomous Engine ──────────────────────────────────────────────────────
AUTONOMOUS_ENABLED=true
AUTONOMOUS_APPROVAL_TIMEOUT_SECONDS=300
AUTONOMOUS_MAX_PLAN_STEPS=15
AUTONOMOUS_BACKGROUND_WORKER_ENABLED=true

# ─── Heartbeat (Proactive System) ───────────────────────────────────────────
HEARTBEAT_ENABLED=true
HEARTBEAT_CHECK_INTERVAL_MINUTES=30
HEARTBEAT_ACTIVE_HOURS_START=07:00
HEARTBEAT_ACTIVE_HOURS_END=23:30
HEARTBEAT_TIMEZONE=Europe/Madrid

# ─── Storage ────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=/app/data/chroma
SQLITE_DB_PATH=/app/data/spesion.db

# ─── Tool Factory (OpenFang-Inspired) ───────────────────────────────────────
# Tool manifests directory (YAML files defining custom tools)
TOOL_MANIFESTS_DIR=/app/tools/manifests
TOOL_REGISTRY_DB=/app/data/tool_registry.db
